{
  "version": 8,
  "sources": {
    "overture": {
      "type": "geojson",
      "data": "./overture.geojson"
    }
  },
  "layers": [{
    "id": "overture-fill",
    "type": "fill",
    "source": "overture",
    "paint": {
      "fill-color": [
        "match",
        ["get", "source_type"],
        "my", "#4caf50",
        "osm", "#2196f3",
        "ml", "#ff9800",
        "#9e9e9e"
      ],
      "fill-opacity": 0.8,
      "fill-outline-color": "#222",
      "fill-outline-width": 1.5
    }
  }]
}